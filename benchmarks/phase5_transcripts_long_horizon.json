{
  "name": "phase5_dialogue_long_horizon_v1",
  "version": "2026-04-04",
  "scenarios": [
    {
      "id": "long_horizon_mixed_context",
      "description": "Twenty-turn mixed-language flow with response-mode toggles, urgency markers, and destructive follow-up safety.",
      "persona": "assistant",
      "turns": [
        {
          "user": "explain mode on",
          "expect_contains": ["Explain mode is on"]
        },
        {
          "user": "open app notepad",
          "expect_contains": ["intent=OS_APP_OPEN"]
        },
        {
          "user": "default mode",
          "expect_contains": ["Default mode restored"]
        },
        {
          "user": "concise mode on",
          "expect_contains": ["Concise mode is on"]
        },
        {
          "user": "open app chrome now quickly",
          "expect_any_contains": ["On it.", "Now."]
        },
        {
          "user": "default mode",
          "expect_contains": ["Default mode restored"]
        },
        {
          "user": "open app edge",
          "expect_contains": ["handled os_app_open"]
        },
        {
          "user": "open app spotify please",
          "expect_contains": ["Understood."]
        },
        {
          "user": "اغلق التطبيق",
          "expect_contains": ["العربية"]
        },
        {
          "user": "file info C:\\Users\\abdel\\Desktop\\report.txt",
          "expect_contains": ["handled os_file_navigation"]
        },
        {
          "user": "delete it",
          "expect_contains": ["For safety", "exact file or path"]
        },
        {
          "user": "explain mode on",
          "expect_contains": ["Explain mode is on"]
        },
        {
          "user": "open app calculator",
          "expect_contains": ["intent=OS_APP_OPEN"]
        },
        {
          "user": "open app vscode",
          "expect_contains": ["handled os_app_open"]
        },
        {
          "user": "default mode",
          "expect_contains": ["Default mode restored"]
        },
        {
          "user": "concise mode on",
          "expect_contains": ["Concise mode is on"]
        },
        {
          "user": "open app notepad now quickly",
          "expect_any_contains": ["On it.", "Now."]
        },
        {
          "user": "default mode",
          "expect_contains": ["Default mode restored"]
        },
        {
          "user": "file info C:\\Users\\abdel\\Desktop\\budget.txt",
          "expect_contains": ["handled os_file_navigation"]
        },
        {
          "user": "delete it",
          "expect_contains": ["For safety", "exact file or path"]
        }
      ]
    }
  ]
}