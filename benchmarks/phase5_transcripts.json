{
  "name": "phase5_dialogue_pack_v2",
  "version": "2026-04-04",
  "scenarios": [
    {
      "id": "explain_mode_en",
      "description": "Enable explain mode and verify rationale is appended for command output.",
      "persona": "professional",
      "turns": [
        {
          "user": "explain mode on",
          "expect_contains": ["Explain mode is on"]
        },
        {
          "user": "open app notepad",
          "expect_contains": ["intent=OS_APP_OPEN", "action=n/a"]
        }
      ]
    },
    {
      "id": "concise_urgency_en",
      "description": "Concise mode plus urgency markers should produce short direct output.",
      "persona": "brief",
      "turns": [
        {
          "user": "concise mode on",
          "expect_contains": ["Concise mode is on"]
        },
        {
          "user": "open app calculator now quickly",
          "expect_any_contains": ["On it.", "Now."]
        }
      ]
    },
    {
      "id": "codeswitch_continuity",
      "description": "Switch EN to AR and keep bilingual continuity bridge.",
      "persona": "friendly",
      "turns": [
        {
          "user": "open app chrome",
          "expect_contains": ["handled os_app_open"]
        },
        {
          "user": "اغلق التطبيق",
          "expect_contains": ["English", "العربية"]
        }
      ]
    },
    {
      "id": "destructive_followup_guardrail",
      "description": "Vague destructive follow-up should be blocked even with prior file context.",
      "persona": "assistant",
      "turns": [
        {
          "user": "file info C:\\Users\\abdel\\Desktop\\report.txt",
          "expect_contains": ["handled os_file_navigation"]
        },
        {
          "user": "delete it",
          "expect_contains": ["For safety", "exact file or path"]
        }
      ]
    }
  ]
}
