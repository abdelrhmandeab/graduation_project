# Jarvis Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Second-factor authentication
JARVIS_SECOND_FACTOR_PIN=change_me
JARVIS_SECOND_FACTOR_PASSPHRASE=change_me

# Phase 4 confirmation hardening
JARVIS_CONFIRMATION_TOKEN_BYTES=8
JARVIS_CONFIRMATION_TOKEN_MIN_HEX_LEN=6
JARVIS_CONFIRMATION_MAX_ATTEMPTS_PER_TOKEN=6
JARVIS_CONFIRMATION_LOCKOUT_SECONDS=120
JARVIS_SECOND_FACTOR_MAX_ATTEMPTS_PER_TOKEN=3
JARVIS_SECOND_FACTOR_LOCKOUT_SECONDS=90

# LLM
JARVIS_LLM_MODEL=qwen2.5:3b
# Qwen models use the Qwen license. If you need an alternative, use llama3.2:3b.
# Leave empty to keep LLM execution pinned to qwen2.5:3b only.
JARVIS_LLM_FALLBACK_MODELS=
JARVIS_LLM_TIMEOUT_SECONDS=30
JARVIS_LLM_OLLAMA_NUM_CTX=2048
# Disable quality-upgrade retries (single-model flow).
JARVIS_LLM_CPU_UPGRADE_TEST_ENABLED=false
JARVIS_LLM_CPU_UPGRADE_MODEL=qwen2.5:3b
JARVIS_LLM_CPU_UPGRADE_MAX_LATENCY_SECONDS=3.0
# Realtime mode: skip expensive post-generation rewrites by default.
JARVIS_LLM_REALTIME_REWRITE_ENABLED=false

# Phase 1 NLU intent routing
JARVIS_NLU_INTENT_ROUTING_ENABLED=true
JARVIS_NLU_INTENT_CONFIDENCE_THRESHOLD=0.75
# Skip extra LLM intent-extraction pass for parser LLM_QUERY turns (latency optimization).
JARVIS_NLU_LLM_QUERY_EXTRACTION_ENABLED=false
JARVIS_NLU_INTENT_CACHE_ENABLED=true
JARVIS_NLU_INTENT_CACHE_MAX_SIZE=256
JARVIS_NLU_INTENT_CACHE_TTL_SECONDS=600
JARVIS_NLU_THRESHOLD_OS_APP_OPEN=0.72
JARVIS_NLU_THRESHOLD_OS_APP_CLOSE=0.74
JARVIS_NLU_THRESHOLD_OS_FILE_SEARCH=0.73
JARVIS_NLU_THRESHOLD_OS_FILE_NAVIGATION=0.74
JARVIS_NLU_THRESHOLD_OS_SYSTEM_COMMAND=0.86
JARVIS_NLU_THRESHOLD_JOB_QUEUE_COMMAND=0.70
JARVIS_NLU_THRESHOLD_VOICE_COMMAND=0.82

# Phase 2.1 adaptive entity confidence / clarification tuning
JARVIS_ENTITY_THRESHOLD_OS_APP_OPEN=0.58
JARVIS_ENTITY_THRESHOLD_OS_APP_CLOSE=0.60
JARVIS_ENTITY_THRESHOLD_OS_FILE_SEARCH=0.56
JARVIS_ENTITY_THRESHOLD_OS_FILE_NAVIGATION=0.56
JARVIS_ENTITY_THRESHOLD_OS_SYSTEM_COMMAND=0.55
JARVIS_ENTITY_THRESHOLD_JOB_QUEUE_COMMAND=0.52
JARVIS_ENTITY_THRESHOLD_ADJUST_EN=0.00
JARVIS_ENTITY_THRESHOLD_ADJUST_AR=-0.02
JARVIS_ENTITY_THRESHOLD_MIXED_LANGUAGE_BONUS=0.03
JARVIS_CLARIFICATION_PREF_MAX_AGE_SECONDS=1209600
JARVIS_CLARIFICATION_FALLBACK_AFTER_MISSES=2

# Phase 2.1 app ranking signal weights
JARVIS_APP_USAGE_BOOST_PER_HIT=0.02
JARVIS_APP_USAGE_BOOST_CAP=0.12
JARVIS_APP_RECENT_BONUS_SECONDS=1800
JARVIS_APP_RUNNING_BONUS_OPEN=0.04
JARVIS_APP_RUNNING_BONUS_CLOSE=0.16
JARVIS_APP_AVAILABLE_BONUS=0.03

# Phase 5 dialogue memory
JARVIS_FOLLOWUP_REFERENCE_MAX_AGE_SECONDS=1800

# Prompt context budgets (lower values reduce CPU latency)
JARVIS_KB_TOP_K=3
JARVIS_KB_MAX_CONTEXT_CHARS=1400
JARVIS_MEMORY_MAX_CONTEXT_CHARS=900

# STT
# Keep faster-whisper as default for fast CPU startup; EgypTalk is optional low-confidence Arabic fallback.
JARVIS_STT_BACKEND=faster_whisper
# Egyptian dialect fallback backend tuning.
JARVIS_STT_EGYPTALK_ENABLED=true
JARVIS_STT_EGYPTALK_MODEL=NAMAA-Space/EgypTalk-ASR-v2
JARVIS_STT_EGYPTALK_TRUST_REMOTE_CODE=false
JARVIS_STT_EGYPTALK_CHUNK_SECONDS=18
JARVIS_STT_EGYPTALK_STRIDE_SECONDS=4
JARVIS_WHISPER_MODEL=large-v3-turbo
JARVIS_WHISPER_DEVICE=cpu
JARVIS_WHISPER_LANGUAGE=auto
JARVIS_MAX_RECORD_DURATION=6
JARVIS_VAD_ENERGY_THRESHOLD=0.015
JARVIS_VAD_SILENCE_SECONDS=0.55
JARVIS_VAD_MIN_SPEECH_SECONDS=0.30
JARVIS_VAD_START_TIMEOUT_SECONDS=3.0

# TTS
JARVIS_TTS_BACKEND=auto
JARVIS_TTS_EDGE_VOICE=en-US-AriaNeural
JARVIS_TTS_EDGE_RATE=+0%
# Arabic Edge-TTS Egyptian profile (with deterministic voice fallbacks).
JARVIS_TTS_EDGE_ARABIC_VOICE=ar-EG-SalmaNeural
JARVIS_TTS_EDGE_ARABIC_VOICE_FALLBACKS=ar-EG-ShakirNeural,ar-SA-HamedNeural
# Slightly slower Arabic rate improves clarity on CPU-only laptops.
JARVIS_TTS_EDGE_ARABIC_RATE=-4%
# Slightly lower pitch + tiny gain reduce "news anchor" tone for many speakers.
JARVIS_TTS_EDGE_ARABIC_PITCH=-8Hz
JARVIS_TTS_EDGE_ARABIC_VOLUME=+4%
JARVIS_TTS_EDGE_MIXED_SCRIPT_CHUNKING=true
JARVIS_TTS_EDGE_MIXED_SCRIPT_MAX_CHUNKS=6
JARVIS_TTS_EDGE_MIXED_SCRIPT_MAX_TEXT_LENGTH=180
JARVIS_TTS_ARABIC_SPOKEN_DIALECT=egyptian
JARVIS_TTS_EGYPTIAN_COLLOQUIAL_REWRITE=true

# Phase 2 bilingual wake-word
JARVIS_WAKE_MODE=both
JARVIS_WAKE_WORD_AR_ENABLED=true
JARVIS_WAKE_WORD_AR_TRIGGERS=hey jarvis,hello jarvis,jarvis,اهلا جارفيس,يا جارفيس,مرحبا جارفس,جارفس
JARVIS_WAKE_WORD_AR_STT_MODEL=tiny
JARVIS_WAKE_WORD_AR_CHUNK_SECONDS=1.5
JARVIS_WAKE_WORD_AR_CHECK_INTERVAL_SECONDS=2.0
JARVIS_WAKE_WORD_AR_CONSECUTIVE_HITS_REQUIRED=2
JARVIS_WAKE_WORD_AR_CONFIRM_WINDOW_SECONDS=3.0

# PowerShell
JARVIS_POWERSHELL_EXECUTABLE=powershell
