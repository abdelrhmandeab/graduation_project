# Jarvis Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Second-factor authentication
JARVIS_SECOND_FACTOR_PIN=change_me
JARVIS_SECOND_FACTOR_PASSPHRASE=change_me

# LLM
JARVIS_LLM_MODEL=qwen2.5:1.5b
JARVIS_LLM_FALLBACK_MODELS=qwen2.5:0.5b
JARVIS_LLM_TIMEOUT_SECONDS=120

# Whisper STT
JARVIS_WHISPER_MODEL=small
JARVIS_WHISPER_DEVICE=cpu

# PowerShell
JARVIS_POWERSHELL_EXECUTABLE=powershell
